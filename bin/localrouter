#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="localrouter"
VERSION="0.1.0"

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
CONFIG_DIR="$CONFIG_HOME/$APP_NAME"
STATE_DIR="$STATE_HOME/$APP_NAME"
CONFIG_FILE="$CONFIG_DIR/config"
MODELS_FILE="$CONFIG_DIR/models.list"
STATE_FILE="$STATE_DIR/state"
LEGACY_STATE_FILE="$STATE_DIR/current_model"
CACHE_FILE="$STATE_DIR/installed.cache"

WINDOWS_USER="${LOCALROUTER_WINDOWS_USER:-}"
WINDOWS_HOST="${LOCALROUTER_WINDOWS_HOST:-}"
SSH_PORT="${LOCALROUTER_SSH_PORT:-22}"
LOCAL_PORT="${LOCALROUTER_LOCAL_PORT:-11434}"
REMOTE_PORT="${LOCALROUTER_REMOTE_PORT:-11434}"
REMOTE_HOST="${LOCALROUTER_REMOTE_HOST:-localhost}"
TARGET_TAG="${LOCALROUTER_TARGET_TAG:-qwen2.5-coder:7b}"
STOP_LOCAL_OLLAMA="${LOCALROUTER_STOP_LOCAL_OLLAMA:-ask}"
SSH_OPTS="${LOCALROUTER_SSH_OPTS:-}"
RETRY_COUNT="${LOCALROUTER_RETRIES:-3}"
RETRY_BACKOFF="${LOCALROUTER_RETRY_BACKOFF:-2}"
PULL_TIMEOUT="${LOCALROUTER_PULL_TIMEOUT:-1800}"
CACHE_TTL="${LOCALROUTER_CACHE_TTL:-60}"
WATCH_BACKOFF_MAX="${LOCALROUTER_WATCH_BACKOFF_MAX:-30}"
PREFLIGHT_OLLAMA="${LOCALROUTER_PREFLIGHT:-1}"

ASSUME_YES=false
KEEP_SESSION=false
SELECTED_MODEL=""
STOP_LOCAL_OLLAMA_OVERRIDE=""
FORCE_PULL=false
FORCE_REFRESH=false

COLOR_RESET=""
COLOR_GREEN=""
COLOR_YELLOW=""
COLOR_BOLD=""
COLOR_DIM=""
COLOR_RED=""

usage() {
    cat <<EOF
$APP_NAME $VERSION

Bridge a local Ollama client to an Ollama server reachable over SSH.

Usage:
  $APP_NAME [global-opts] <verb> [args]
  $APP_NAME                          (interactive: pick a model + open tunnel)

Verbs:
  use MODEL                Pull/copy MODEL on the remote host then open the tunnel.
  list                     Show configured models with installed status and size.
  status                   Show config, tracked model, tunnel state, last-used timestamps.
  kill                     Close any running localrouter SSH tunnel.
  restart                  Kill the tunnel and reopen it with the tracked model.
  info MODEL               Print ollama metadata (params/quant/template) for MODEL.
  watch                    Foreground supervisor: auto-reconnect tunnel on drop.
  setup                    Interactive config wizard for $CONFIG_FILE.
  setup windows            Bootstrap the Windows host over SSH (sshd, firewall).
  setup ssh-key            Generate and install a per-host SSH key for passwordless auth.
  edit-models              Edit the local model list interactively.
  init-config              Create config and model-list templates if missing.

Global options:
  --keep                   Open or keep the tunnel without changing the tracked model.
  --force                  Force re-pull of the model even if already installed.
  --refresh                Force refresh of the installed-models cache.
  --no-preflight           Skip the 'ollama list' preflight before remote operations.
  --retries N              Override remote retry count (default 3; LOCALROUTER_RETRIES).
  --pull-timeout SECS      Override ollama-pull timeout (default 1800; LOCALROUTER_PULL_TIMEOUT).
  --yes                    Answer yes to interactive prompts.
  --no-stop-local-ollama   Do not offer to stop local ollama when it owns the port.
  --help, -h               Show this help.
  --version                Print the version.

Legacy flag aliases (kept for backward compatibility):
  --model MODEL  == use MODEL
  --status       == status
  --setup        == setup
  --setup-windows == setup windows
  --setup-ssh-key == setup ssh-key
  --edit-models  == edit-models
  --init-config  == init-config

Config:    $CONFIG_FILE
Models:    $MODELS_FILE
State:     $STATE_FILE

Required config values: WINDOWS_USER, WINDOWS_HOST
EOF
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

info() {
    printf '%s\n' "$*"
}

ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$STATE_DIR"
    chmod 700 "$CONFIG_DIR" "$STATE_DIR"
}

write_default_config() {
    ensure_dirs
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat >"$CONFIG_FILE" <<'EOF'
# localrouter config
#
# Required:
# WINDOWS_USER="your-windows-user"
# WINDOWS_HOST="192.168.1.50"
#
# Optional:
# SSH_PORT="22"
# LOCAL_PORT="11434"
# REMOTE_HOST="localhost"
# REMOTE_PORT="11434"
# TARGET_TAG="qwen2.5-coder:7b"
# STOP_LOCAL_OLLAMA="ask"     # ask, yes, or no
# SSH_OPTS="-o ServerAliveInterval=30 -o ExitOnForwardFailure=yes"
EOF
        chmod 600 "$CONFIG_FILE"
        info "Created $CONFIG_FILE"
    fi

    if [[ ! -f "$MODELS_FILE" ]]; then
        cat >"$MODELS_FILE" <<'EOF'
qwen2.5-coder:7b-instruct-q4_K_M
deepseek-coder:7b
gemma3:4b-q8_0
EOF
        chmod 600 "$MODELS_FILE"
        info "Created $MODELS_FILE"
    fi
}

# ---- state file ----------------------------------------------------------
# Format: key=value, single-quoted values. Bash-sourceable.
#   TRACKED_MODEL='qwen2.5-coder:7b'
#   LAST_TUNNEL_AT='1716050000'
#   LAST_PULL_AT='1716049000'
#   LAST_USE_AT='1716050100'

TRACKED_MODEL=""
LAST_TUNNEL_AT=""
LAST_PULL_AT=""
LAST_USE_AT=""

read_state() {
    ensure_dirs
    TRACKED_MODEL=""
    LAST_TUNNEL_AT=""
    LAST_PULL_AT=""
    LAST_USE_AT=""
    if [[ -f "$STATE_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$STATE_FILE"
    elif [[ -f "$LEGACY_STATE_FILE" ]]; then
        TRACKED_MODEL="$(<"$LEGACY_STATE_FILE")"
        TRACKED_MODEL="${TRACKED_MODEL%$'\n'}"
        write_state
        rm -f "$LEGACY_STATE_FILE"
    fi
}

write_state() {
    ensure_dirs
    local tmp
    tmp="$(mktemp "$STATE_DIR/.state.XXXXXX")" || die "could not create temp file in $STATE_DIR"
    {
        printf '# localrouter state (auto-managed)\n'
        printf 'TRACKED_MODEL=%s\n' "$(quote_for_config "$TRACKED_MODEL")"
        printf 'LAST_TUNNEL_AT=%s\n' "$(quote_for_config "$LAST_TUNNEL_AT")"
        printf 'LAST_PULL_AT=%s\n'   "$(quote_for_config "$LAST_PULL_AT")"
        printf 'LAST_USE_AT=%s\n'    "$(quote_for_config "$LAST_USE_AT")"
    } >"$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$STATE_FILE"
}

state_set() {
    read_state
    while [[ $# -gt 0 ]]; do
        case "$1" in
            TRACKED_MODEL) TRACKED_MODEL="$2" ;;
            LAST_TUNNEL_AT) LAST_TUNNEL_AT="$2" ;;
            LAST_PULL_AT) LAST_PULL_AT="$2" ;;
            LAST_USE_AT) LAST_USE_AT="$2" ;;
            *) die "unknown state key: $1" ;;
        esac
        shift 2
    done
    write_state
}

# ---- installed-models cache ---------------------------------------------
# Format: tab-separated <tag>\t<id>\t<size>\t<modified>

cache_age() {
    if [[ ! -f "$CACHE_FILE" ]]; then
        printf '%d' "$((10**9))"
        return
    fi
    local now mtime
    now="$(date +%s)"
    mtime="$(stat -c %Y "$CACHE_FILE" 2>/dev/null || stat -f %m "$CACHE_FILE" 2>/dev/null || echo 0)"
    printf '%d' "$((now - mtime))"
}

cache_invalidate() {
    rm -f "$CACHE_FILE"
}

parse_ollama_list() {
    awk 'NR > 1 && NF > 0 {
        name=$1
        id=$2
        size=$3 " " $4
        modified=""
        for (i=5; i<=NF; i++) modified = (modified == "" ? $i : modified " " $i)
        printf "%s\t%s\t%s\t%s\n", name, id, size, modified
    }'
}

_run_remote_list() {
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=(-o BatchMode=yes "ollama list")
    "${cmd[@]}"
}

refresh_installed_cache() {
    local raw parsed
    raw="$(with_retries "ollama list" _run_remote_list)" || return 1
    parsed="$(printf '%s\n' "$raw" | parse_ollama_list)"
    ensure_dirs
    local tmp
    tmp="$(mktemp "$STATE_DIR/.cache.XXXXXX")" || die "could not create temp file in $STATE_DIR"
    printf '%s\n' "$parsed" >"$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$CACHE_FILE"
}

ensure_installed_cache() {
    if [[ "$FORCE_REFRESH" == true ]] || (( $(cache_age) > CACHE_TTL )); then
        refresh_installed_cache
    fi
}

installed_tags() {
    [[ -f "$CACHE_FILE" ]] || return 0
    awk -F '\t' '{print $1}' "$CACHE_FILE"
}

is_installed() {
    local tag="$1"
    [[ -f "$CACHE_FILE" ]] || return 1
    awk -F '\t' -v t="$tag" '$1 == t {found=1; exit} END {exit !found}' "$CACHE_FILE"
}

installed_size() {
    local tag="$1"
    [[ -f "$CACHE_FILE" ]] || return 1
    awk -F '\t' -v t="$tag" '$1 == t {print $3; exit}' "$CACHE_FILE"
}

load_config() {
    ensure_dirs
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi

    WINDOWS_USER="${LOCALROUTER_WINDOWS_USER:-${WINDOWS_USER:-}}"
    WINDOWS_HOST="${LOCALROUTER_WINDOWS_HOST:-${WINDOWS_HOST:-}}"
    SSH_PORT="${LOCALROUTER_SSH_PORT:-${SSH_PORT:-22}}"
    LOCAL_PORT="${LOCALROUTER_LOCAL_PORT:-${LOCAL_PORT:-11434}}"
    REMOTE_PORT="${LOCALROUTER_REMOTE_PORT:-${REMOTE_PORT:-11434}}"
    REMOTE_HOST="${LOCALROUTER_REMOTE_HOST:-${REMOTE_HOST:-localhost}}"
    TARGET_TAG="${LOCALROUTER_TARGET_TAG:-${TARGET_TAG:-qwen2.5-coder:7b}}"
    STOP_LOCAL_OLLAMA="${LOCALROUTER_STOP_LOCAL_OLLAMA:-${STOP_LOCAL_OLLAMA:-ask}}"
    SSH_OPTS="${LOCALROUTER_SSH_OPTS:-${SSH_OPTS:-}}"
    RETRY_COUNT="${LOCALROUTER_RETRIES:-${RETRY_COUNT:-3}}"
    RETRY_BACKOFF="${LOCALROUTER_RETRY_BACKOFF:-${RETRY_BACKOFF:-2}}"
    PULL_TIMEOUT="${LOCALROUTER_PULL_TIMEOUT:-${PULL_TIMEOUT:-1800}}"
    CACHE_TTL="${LOCALROUTER_CACHE_TTL:-${CACHE_TTL:-60}}"
    WATCH_BACKOFF_MAX="${LOCALROUTER_WATCH_BACKOFF_MAX:-${WATCH_BACKOFF_MAX:-30}}"
    PREFLIGHT_OLLAMA="${LOCALROUTER_PREFLIGHT:-${PREFLIGHT_OLLAMA:-1}}"
}

setup_colors() {
    if [[ "${NO_COLOR:-}" != "" ]] || [[ ! -t 1 ]]; then
        return
    fi
    COLOR_RESET=$'\033[0m'
    COLOR_GREEN=$'\033[32m'
    COLOR_YELLOW=$'\033[33m'
    COLOR_BOLD=$'\033[1m'
    COLOR_DIM=$'\033[2m'
    COLOR_RED=$'\033[31m'
}

validate_port() {
    local value="$1"
    local name="$2"
    [[ "$value" =~ ^[0-9]+$ ]] || die "$name must be a port number"
    (( value >= 1 && value <= 65535 )) || die "$name must be between 1 and 65535"
}

validate_model_tag() {
    local value="$1"
    local name="$2"
    [[ -n "$value" ]] || die "$name cannot be empty"
    [[ "$value" =~ ^[A-Za-z0-9][A-Za-z0-9._/-]*(:[A-Za-z0-9][A-Za-z0-9._-]*)?$ ]] \
        || die "$name contains unsupported characters: $value"
}

validate_windows_user() {
    local value="$1"
    local name="$2"
    [[ -n "$value" ]] || die "$name cannot be empty"
    [[ "$value" =~ ^[A-Za-z_][A-Za-z0-9._-]{0,31}$ ]] \
        || die "$name contains unsupported characters (allowed: letters, digits, dot, underscore, hyphen): $value"
}

validate_windows_host() {
    local value="$1"
    local name="$2"
    [[ -n "$value" ]] || die "$name cannot be empty"
    [[ "$value" =~ ^[A-Za-z0-9]([A-Za-z0-9.-]{0,253}[A-Za-z0-9])?$ ]] \
        || die "$name must be a hostname or IPv4 literal (IPv6 is not yet supported): $value"
}

validate_config() {
    [[ -n "$WINDOWS_USER" ]] || die "WINDOWS_USER is not configured. Run '$APP_NAME --setup' or '$APP_NAME --init-config'."
    [[ -n "$WINDOWS_HOST" ]] || die "WINDOWS_HOST is not configured. Run '$APP_NAME --setup' or '$APP_NAME --init-config'."
    validate_windows_user "$WINDOWS_USER" "WINDOWS_USER"
    validate_windows_host "$WINDOWS_HOST" "WINDOWS_HOST"
    validate_port "$SSH_PORT" "SSH_PORT"
    validate_port "$LOCAL_PORT" "LOCAL_PORT"
    validate_port "$REMOTE_PORT" "REMOTE_PORT"
    validate_model_tag "$TARGET_TAG" "TARGET_TAG"
    case "$STOP_LOCAL_OLLAMA" in
        ask|yes|no) ;;
        *) die "STOP_LOCAL_OLLAMA must be ask, yes, or no" ;;
    esac
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

validate_retry_args() {
    [[ "$RETRY_COUNT" =~ ^[0-9]+$ ]] || die "RETRY_COUNT must be a non-negative integer"
    [[ "$RETRY_BACKOFF" =~ ^[0-9]+$ ]] || die "RETRY_BACKOFF must be a non-negative integer (seconds)"
}

with_retries() {
    local label="$1"
    shift
    validate_retry_args
    local attempts=$((RETRY_COUNT + 1))
    local i=1
    local rc=0
    while (( i <= attempts )); do
        if (( attempts > 1 )); then
            info "[$label] attempt $i/$attempts"
        fi
        rc=0
        "$@" || rc=$?
        if (( rc == 0 )); then
            return 0
        fi
        if (( i < attempts )); then
            local delay=$(( RETRY_BACKOFF * i ))
            info "[$label] failed with exit $rc; retrying in ${delay}s"
            sleep "$delay"
        fi
        ((i++))
    done
    die "$label failed after $attempts attempt(s) (last exit code: $rc)"
}

ssh_base() {
    local -a cmd=(ssh -p "$SSH_PORT")
    if [[ -n "$SSH_OPTS" ]]; then
        # shellcheck disable=SC2206
        local -a extra_opts=($SSH_OPTS)
        cmd+=("${extra_opts[@]}")
    fi
    cmd+=("$WINDOWS_USER@$WINDOWS_HOST")
    printf '%s\0' "${cmd[@]}"
}

shell_quote() {
    local value="$1"
    printf "'%s'" "${value//\'/\'\\\'\'}"
}

_run_remote_pull() {
    local quoted_model="$1"
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=("ollama pull $quoted_model")
    if command -v timeout >/dev/null 2>&1; then
        timeout "$PULL_TIMEOUT" "${cmd[@]}"
    else
        "${cmd[@]}"
    fi
}

_run_remote_cp() {
    local quoted_model="$1" quoted_target="$2"
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=("ollama cp $quoted_model $quoted_target")
    "${cmd[@]}"
}

preflight_ollama() {
    if [[ "$PREFLIGHT_OLLAMA" != "1" ]]; then
        return 0
    fi
    if ! ( refresh_installed_cache ) 2>/dev/null; then
        die "preflight failed: could not run 'ollama list' on $WINDOWS_USER@$WINDOWS_HOST. Is Ollama running on Windows? Try: ssh $WINDOWS_USER@$WINDOWS_HOST 'ollama list'"
    fi
}

remote_ollama_swap() {
    local model="$1"
    local quoted_model quoted_target
    validate_model_tag "$model" "MODEL"
    quoted_model="$(shell_quote "$model")"
    quoted_target="$(shell_quote "$TARGET_TAG")"

    preflight_ollama

    if [[ "$FORCE_PULL" != true ]] && is_installed "$model"; then
        info "${COLOR_GREEN}*${COLOR_RESET} ${model} already installed on $WINDOWS_HOST; skipping pull (use --force to re-pull)"
    else
        [[ "$FORCE_PULL" == true ]] && info "Force-pulling $model"
        info "Pulling $model (timeout ${PULL_TIMEOUT}s)"
        with_retries "ollama pull" _run_remote_pull "$quoted_model"
        state_set LAST_PULL_AT "$(date +%s)"
        cache_invalidate
    fi

    if [[ "$model" != "$TARGET_TAG" ]]; then
        info "Copying $model -> $TARGET_TAG"
        with_retries "ollama cp" _run_remote_cp "$quoted_model" "$quoted_target"
        cache_invalidate
    fi
}

is_tunnel_active() {
    pgrep -f "ssh .* -L ${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" >/dev/null 2>&1
}

is_port_listening() {
    ss -tuln | awk '{print $5}' | grep -Eq "(^|:)${LOCAL_PORT}$"
}

stop_local_ollama_if_needed() {
    if ! is_port_listening; then
        return
    fi
    if is_tunnel_active; then
        return
    fi
    if ! command -v systemctl >/dev/null 2>&1; then
        die "local port $LOCAL_PORT is already in use"
    fi
    if ! systemctl is-active --quiet ollama; then
        die "local port $LOCAL_PORT is already in use"
    fi

    case "$STOP_LOCAL_OLLAMA" in
        no)
            die "local ollama owns port $LOCAL_PORT; set STOP_LOCAL_OLLAMA=ask or yes to stop it"
            ;;
        ask)
            if [[ "$ASSUME_YES" != true ]]; then
                read -r -p "Local ollama owns port $LOCAL_PORT. Stop it with sudo systemctl stop ollama? [y/N] " answer
                [[ "$answer" =~ ^[Yy]$ ]] || die "cannot open tunnel while local port $LOCAL_PORT is in use"
            fi
            ;;
        yes) ;;
    esac

    sudo systemctl stop ollama
}

read_models() {
    if [[ ! -f "$MODELS_FILE" ]]; then
        write_default_config >/dev/null
    fi
    mapfile -t MODELS <"$MODELS_FILE"

    local clean_models=()
    local model
    for model in "${MODELS[@]}"; do
        [[ -n "$model" ]] || continue
        validate_model_tag "$model" "model in $MODELS_FILE"
        clean_models+=("$model")
    done
    MODELS=("${clean_models[@]}")
}

save_models() {
    : >"$MODELS_FILE"
    local model
    for model in "${MODELS[@]}"; do
        printf '%s\n' "$model" >>"$MODELS_FILE"
    done
    chmod 600 "$MODELS_FILE"
}

edit_models() {
    read_models
    local selected=0
    local key key2 key3 new_model
    while true; do
        clear
        echo "=========================================="
        echo "              Edit Models                 "
        echo "=========================================="
        echo "UP/DOWN navigate | d/delete remove | a add | q quit"
        echo "------------------------------------------"
        if [[ ${#MODELS[@]} -eq 0 ]]; then
            echo " (No models in the list)"
        else
            if (( selected >= ${#MODELS[@]} )); then selected=$((${#MODELS[@]} - 1)); fi
            if (( selected < 0 )); then selected=0; fi

            for i in "${!MODELS[@]}"; do
                if (( i == selected )); then
                    echo " > ${MODELS[$i]}"
                else
                    echo "   ${MODELS[$i]}"
                fi
            done
        fi
        echo "=========================================="

        read -rsn1 key
        if [[ $key == $'\x1b' ]]; then
            read -rsn2 -t 0.1 key2 || true
            if [[ $key2 == "[A" ]]; then
                ((selected--)) || true
                if (( selected < 0 )); then selected=$((${#MODELS[@]} - 1)); fi
            elif [[ $key2 == "[B" ]]; then
                ((selected++)) || true
                if (( selected >= ${#MODELS[@]} )); then selected=0; fi
            elif [[ $key2 == "[3" ]]; then
                read -rsn1 -t 0.1 key3 || true
                if [[ $key3 == "~" ]]; then key="delete"; fi
            fi
        fi

        if [[ $key == "delete" || $key == "d" || $key == $'\x7f' || $key == $'\b' ]]; then
            if [[ ${#MODELS[@]} -gt 0 ]]; then
                unset 'MODELS[selected]'
                MODELS=("${MODELS[@]}")
                if (( selected >= ${#MODELS[@]} && ${#MODELS[@]} > 0 )); then
                    ((selected--)) || true
                elif [[ ${#MODELS[@]} -eq 0 ]]; then
                    selected=0
                fi
                save_models
            fi
        elif [[ $key == "a" || $key == "A" ]]; then
            printf '\nEnter new model name: '
            read -r new_model
            if [[ -n "$new_model" ]]; then
                validate_model_tag "$new_model" "MODEL"
                MODELS+=("$new_model")
                save_models
                selected=$((${#MODELS[@]} - 1))
            fi
        elif [[ $key == "q" || $key == "Q" ]]; then
            break
        fi
    done
}

current_model() {
    read_state
    if [[ -n "$TRACKED_MODEL" ]]; then
        printf '%s' "$TRACKED_MODEL"
    else
        printf 'Unknown'
    fi
}

choose_model() {
    read_models
    local current keep_opt refresh_opt choice i tag color label size
    current="$(current_model)"
    ( ensure_installed_cache ) 2>/dev/null || info "(warning: could not refresh installed-models cache; menu will not mark installed state)"
    while true; do
        clear
        echo "=========================================="
        echo "           Local AI Router                "
        echo "=========================================="
        echo "Remote: $WINDOWS_USER@$WINDOWS_HOST:$SSH_PORT"
        echo "Tunnel: localhost:$LOCAL_PORT -> $REMOTE_HOST:$REMOTE_PORT"
        echo "Tracked model: ${COLOR_BOLD}${current}${COLOR_RESET}"
        if is_tunnel_active; then
            echo "Status: ${COLOR_GREEN}active tunnel detected${COLOR_RESET}"
        else
            echo "Status: disconnected"
        fi
        echo "------------------------------------------"
        if [[ ${#MODELS[@]} -eq 0 ]]; then
            echo " (No models available. Press 0 to edit list)"
        else
            for i in "${!MODELS[@]}"; do
                tag="${MODELS[$i]}"
                if is_installed "$tag"; then
                    color="$COLOR_GREEN"
                    label="installed"
                    size="$(installed_size "$tag" 2>/dev/null || true)"
                    [[ -n "$size" ]] && label="$label, $size"
                else
                    color="$COLOR_YELLOW"
                    label="not pulled"
                fi
                if [[ "$tag" == "$current" ]]; then
                    printf ' [%d] %b%s%b  %b[%s, tracked]%b\n' \
                        "$((i + 1))" "$COLOR_BOLD" "$tag" "$COLOR_RESET" "$color" "$label" "$COLOR_RESET"
                else
                    printf ' [%d] %s  %b[%s]%b\n' \
                        "$((i + 1))" "$tag" "$color" "$label" "$COLOR_RESET"
                fi
            done
        fi
        keep_opt=$((${#MODELS[@]} + 1))
        refresh_opt=$((${#MODELS[@]} + 2))
        echo " [$keep_opt] Keep current session"
        echo " [$refresh_opt] Refresh installed list"
        echo " [0] Edit model list"
        echo "=========================================="

        read -r -p "Select an option (0-$refresh_opt): " choice
        echo

        if [[ "$choice" == "0" ]]; then
            edit_models
            read_models
        elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#MODELS[@]} )); then
            SELECTED_MODEL="${MODELS[$((choice - 1))]}"
            break
        elif [[ "$choice" == "$keep_opt" ]]; then
            KEEP_SESSION=true
            break
        elif [[ "$choice" == "$refresh_opt" ]]; then
            FORCE_REFRESH=true
            ( ensure_installed_cache ) 2>/dev/null || info "(refresh failed)"
            FORCE_REFRESH=false
        else
            read -r -p "Invalid selection. Press enter to try again." _
        fi
    done
}

show_status() {
    printf 'Config: %s\n' "$CONFIG_FILE"
    printf 'Models: %s\n' "$MODELS_FILE"
    printf 'Remote: %s@%s:%s\n' "${WINDOWS_USER:-<unset>}" "${WINDOWS_HOST:-<unset>}" "$SSH_PORT"
    printf 'Tunnel: localhost:%s -> %s:%s\n' "$LOCAL_PORT" "$REMOTE_HOST" "$REMOTE_PORT"
    printf 'Target tag: %s\n' "$TARGET_TAG"
    printf 'Tracked model: %s\n' "$(current_model)"
    if is_tunnel_active; then
        printf 'Tunnel status: active\n'
    else
        printf 'Tunnel status: inactive\n'
    fi
}

quote_for_config() {
    local v="$1"
    printf "'%s'" "${v//\'/\'\\\'\'}"
}

write_config_atomic() {
    local content="$1"
    ensure_dirs
    local tmp
    tmp="$(mktemp "$CONFIG_DIR/.config.XXXXXX")" || die "could not create temp file in $CONFIG_DIR"
    printf '%s' "$content" >"$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$CONFIG_FILE"
}

prompt_value() {
    local label="$1" default="$2" input
    if [[ -n "$default" ]]; then
        read -r -p "$label [$default]: " input
        printf '%s' "${input:-$default}"
    else
        read -r -p "$label: " input
        printf '%s' "$input"
    fi
}

build_config_content() {
    cat <<EOF
# localrouter config (managed by --setup; safe to edit by hand)
WINDOWS_USER=$(quote_for_config "$WINDOWS_USER")
WINDOWS_HOST=$(quote_for_config "$WINDOWS_HOST")
SSH_PORT=$(quote_for_config "$SSH_PORT")
LOCAL_PORT=$(quote_for_config "$LOCAL_PORT")
REMOTE_HOST=$(quote_for_config "$REMOTE_HOST")
REMOTE_PORT=$(quote_for_config "$REMOTE_PORT")
TARGET_TAG=$(quote_for_config "$TARGET_TAG")
STOP_LOCAL_OLLAMA=$(quote_for_config "$STOP_LOCAL_OLLAMA")
SSH_OPTS=$(quote_for_config "$SSH_OPTS")
RETRY_COUNT=$(quote_for_config "$RETRY_COUNT")
RETRY_BACKOFF=$(quote_for_config "$RETRY_BACKOFF")
EOF
}

run_setup() {
    load_config
    echo "=========================================="
    echo "         localrouter first-time setup     "
    echo "=========================================="
    echo "Press Enter to keep the value in [brackets]. Ctrl+C to abort."
    echo "------------------------------------------"

    local val
    while true; do
        val="$(prompt_value "Windows username" "$WINDOWS_USER")"
        if validate_windows_user "$val" "WINDOWS_USER" 2>/dev/null; then
            WINDOWS_USER="$val"; break
        else
            echo "  -> invalid username (letters, digits, dot, underscore, hyphen; <=32 chars)"
        fi
    done
    while true; do
        val="$(prompt_value "Windows host (IP or DNS)" "$WINDOWS_HOST")"
        if validate_windows_host "$val" "WINDOWS_HOST" 2>/dev/null; then
            WINDOWS_HOST="$val"; break
        else
            echo "  -> invalid hostname or IPv4 literal"
        fi
    done
    while true; do
        val="$(prompt_value "SSH port" "${SSH_PORT:-22}")"
        if validate_port "$val" "SSH_PORT" 2>/dev/null; then SSH_PORT="$val"; break; else echo "  -> port must be 1-65535"; fi
    done
    while true; do
        val="$(prompt_value "Local port to bind on this machine" "${LOCAL_PORT:-11434}")"
        if validate_port "$val" "LOCAL_PORT" 2>/dev/null; then LOCAL_PORT="$val"; break; else echo "  -> port must be 1-65535"; fi
    done
    REMOTE_HOST="$(prompt_value "Remote bind host (as seen from Windows)" "${REMOTE_HOST:-localhost}")"
    while true; do
        val="$(prompt_value "Remote port (Ollama on Windows)" "${REMOTE_PORT:-11434}")"
        if validate_port "$val" "REMOTE_PORT" 2>/dev/null; then REMOTE_PORT="$val"; break; else echo "  -> port must be 1-65535"; fi
    done
    while true; do
        val="$(prompt_value "Default target tag (alias Ollama uses after cp)" "${TARGET_TAG:-qwen2.5-coder:7b}")"
        if validate_model_tag "$val" "TARGET_TAG" 2>/dev/null; then TARGET_TAG="$val"; break; else echo "  -> see docs for tag format"; fi
    done
    while true; do
        val="$(prompt_value "Stop local ollama if it owns the port? (ask/yes/no)" "${STOP_LOCAL_OLLAMA:-ask}")"
        case "$val" in ask|yes|no) STOP_LOCAL_OLLAMA="$val"; break ;; *) echo "  -> must be ask, yes, or no" ;; esac
    done
    SSH_OPTS="$(prompt_value "Extra SSH options (space-separated, optional)" "${SSH_OPTS:-}")"
    while true; do
        val="$(prompt_value "Retry count for remote ops" "${RETRY_COUNT:-3}")"
        if [[ "$val" =~ ^[0-9]+$ ]]; then RETRY_COUNT="$val"; break; else echo "  -> must be a non-negative integer"; fi
    done
    while true; do
        val="$(prompt_value "Retry backoff seconds (multiplied by attempt #)" "${RETRY_BACKOFF:-2}")"
        if [[ "$val" =~ ^[0-9]+$ ]]; then RETRY_BACKOFF="$val"; break; else echo "  -> must be a non-negative integer"; fi
    done

    local content
    content="$(build_config_content)"
    write_config_atomic "$content"
    info "Wrote $CONFIG_FILE"

    if [[ ! -f "$MODELS_FILE" ]]; then
        write_default_config >/dev/null
    fi

    if [[ "$ASSUME_YES" == true ]]; then return; fi
    local answer
    read -r -p "Test SSH connection to $WINDOWS_USER@$WINDOWS_HOST:$SSH_PORT now? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        local -a cmd
        readarray -d '' -t cmd < <(ssh_base)
        cmd+=(-o BatchMode=no -o ConnectTimeout=10 "echo ok")
        if "${cmd[@]}"; then
            info "SSH connection OK."
        else
            info "SSH test failed. If this is the first connection, accept the host key and try again; otherwise check credentials or firewall."
        fi
    fi
}

escape_ps_single() {
    local v="$1"
    printf '%s' "${v//\'/\'\'}"
}

_setup_ssh_key_ps_body() {
    cat <<'PSEOF'
$ErrorActionPreference = 'Continue'
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]'Administrator')
if ($isAdmin) {
    $sshDir = 'C:\ProgramData\ssh'
    $authFile = Join-Path $sshDir 'administrators_authorized_keys'
    $scope = 'administrators'
} else {
    $sshDir = Join-Path $env:USERPROFILE '.ssh'
    $authFile = Join-Path $sshDir 'authorized_keys'
    $scope = $env:USERNAME
}
Write-Output ("authorized_keys target: " + $authFile + " (scope: " + $scope + ")")

if (!(Test-Path $sshDir)) {
    New-Item -ItemType Directory -Path $sshDir -Force | Out-Null
    Write-Output ("created directory: " + $sshDir)
}
if (!(Test-Path $authFile)) {
    New-Item -ItemType File -Path $authFile -Force | Out-Null
    Write-Output ("created file: " + $authFile)
}

$existing = @()
if (Test-Path $authFile) { $existing = Get-Content $authFile -ErrorAction SilentlyContinue }
if ($existing -contains $Pubkey) {
    Write-Output "key already present; no change"
} else {
    Add-Content -Path $authFile -Value $Pubkey
    Write-Output "key appended"
}

if ($isAdmin) {
    icacls $authFile /inheritance:r | Out-Null
    icacls $authFile /grant "Administrators:F" "SYSTEM:F" | Out-Null
} else {
    icacls $authFile /inheritance:r | Out-Null
    icacls $authFile /grant "${scope}:F" | Out-Null
}
Write-Output "permissions tightened"
PSEOF
}

_run_setup_ssh_key() {
    local pubkey_escaped="$1"
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=(powershell -NoProfile -Command -)
    {
        printf "\$Pubkey = '%s'\n" "$pubkey_escaped"
        _setup_ssh_key_ps_body
    } | "${cmd[@]}"
}

run_setup_ssh_key() {
    load_config
    validate_config
    require_command ssh
    require_command ssh-keygen

    local key_path="$HOME/.ssh/localrouter_${WINDOWS_HOST}"
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"

    if [[ ! -f "$key_path" ]]; then
        info "Generating ed25519 key at $key_path (no passphrase)"
        ssh-keygen -t ed25519 -N "" -C "localrouter@${WINDOWS_HOST}" -f "$key_path" >/dev/null
    else
        info "Key already exists: $key_path"
    fi

    local pubkey
    pubkey="$(< "${key_path}.pub")"
    pubkey="${pubkey%$'\n'}"
    [[ -n "$pubkey" ]] || die "could not read $key_path.pub"

    info "Installing public key on $WINDOWS_USER@$WINDOWS_HOST"
    local pubkey_escaped
    pubkey_escaped="$(escape_ps_single "$pubkey")"
    with_retries "setup-ssh-key" _run_setup_ssh_key "$pubkey_escaped"

    if [[ "$SSH_OPTS" != *"-i $key_path"* ]]; then
        if [[ -n "$SSH_OPTS" ]]; then
            SSH_OPTS="$SSH_OPTS -i $key_path"
        else
            SSH_OPTS="-i $key_path"
        fi
        write_config_atomic "$(build_config_content)"
        info "Added '-i $key_path' to SSH_OPTS in $CONFIG_FILE"
    else
        info "SSH_OPTS already references $key_path"
    fi

    if [[ "$ASSUME_YES" != true ]]; then
        local answer
        read -r -p "Test passwordless SSH now? [y/N] " answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            local -a cmd
            readarray -d '' -t cmd < <(ssh_base)
            cmd+=(-o BatchMode=yes -o ConnectTimeout=10 "echo ok")
            if "${cmd[@]}"; then
                info "Passwordless SSH OK."
            else
                info "Passwordless SSH failed. If the key was just installed and the host requires interactive admin elevation, try once more with a password. Otherwise check the authorized_keys path on Windows."
            fi
        fi
    fi
}

_setup_windows_ps_body() {
    cat <<'PSEOF'
$ErrorActionPreference = 'Continue'
$results = @{}

function Note($key, $value) { $script:results[$key] = $value; Write-Output ("   {0,-30} {1}" -f $key, $value) }

Write-Output "=========================================="
Write-Output " localrouter -> Windows host bootstrap"
Write-Output "=========================================="

Write-Output "-> 1/5 OpenSSH Server service"
$svc = Get-Service -Name sshd -ErrorAction SilentlyContinue
if ($null -eq $svc) {
    Note "sshd_service" "NOT INSTALLED (run on Windows: Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0)"
    exit 2
}
if ($svc.StartType -ne 'Automatic') {
    Set-Service -Name sshd -StartupType Automatic
    Note "sshd_startup" "set to Automatic"
} else {
    Note "sshd_startup" "already Automatic"
}
if ($svc.Status -ne 'Running') {
    Start-Service -Name sshd
    Note "sshd_status" "started"
} else {
    Note "sshd_status" "already Running"
}

Write-Output "-> 2/5 Network profile"
$nonPrivate = Get-NetConnectionProfile | Where-Object NetworkCategory -ne 'Private'
if ($nonPrivate) {
    foreach ($p in $nonPrivate) {
        try {
            Set-NetConnectionProfile -InterfaceIndex $p.InterfaceIndex -NetworkCategory Private
            Note ("profile_" + $p.InterfaceAlias) "set Private"
        } catch {
            Note ("profile_" + $p.InterfaceAlias) ("FAILED: " + $_.Exception.Message)
        }
    }
} else {
    Note "profile" "all already Private"
}

Write-Output "-> 3/5 Firewall rule for SSH port $Port"
$existing = Get-NetFirewallRule -DisplayName "localrouter SSH inbound" -ErrorAction SilentlyContinue
if ($existing) {
    Note "firewall_rule" "already present (localrouter SSH inbound)"
} else {
    try {
        New-NetFirewallRule -DisplayName "localrouter SSH inbound" `
            -Direction Inbound -Action Allow -Protocol TCP -LocalPort $Port `
            -Profile Any -Enabled True | Out-Null
        Note "firewall_rule" "created (TCP $Port inbound, all profiles)"
    } catch {
        Note "firewall_rule" ("FAILED: " + $_.Exception.Message)
    }
}

Write-Output "-> 4/5 ollama on PATH for this SSH session"
$ollama = Get-Command ollama -ErrorAction SilentlyContinue
if ($ollama) {
    Note "ollama_path" $ollama.Source
} else {
    Note "ollama_path" "NOT FOUND on PATH for SSH user; add Ollama install dir to System PATH"
}

Write-Output "-> 5/5 sshd listening on port $Port"
$listening = (Get-NetTCPConnection -State Listen -LocalPort $Port -ErrorAction SilentlyContinue)
if ($listening) {
    Note "sshd_listening" "yes"
} else {
    Note "sshd_listening" "no (sshd may be binding only on IPv6 or another port)"
}

Write-Output "=========================================="
Write-Output " Bootstrap complete."
Write-Output "=========================================="
PSEOF
}

_run_setup_windows() {
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=(powershell -NoProfile -Command -)
    {
        printf '$Port = %d\n' "$SSH_PORT"
        _setup_windows_ps_body
    } | "${cmd[@]}"
}

run_setup_windows() {
    load_config
    validate_config
    require_command ssh

    echo "=========================================="
    echo " localrouter --setup-windows"
    echo "=========================================="
    echo "Remote: $WINDOWS_USER@$WINDOWS_HOST:$SSH_PORT"
    echo
    echo "This will run idempotent PowerShell on the Windows host that:"
    echo "  - sets the sshd service to Automatic startup and starts it"
    echo "  - sets non-Private network profiles to Private (so the firewall rule applies)"
    echo "  - adds (if missing) a firewall rule 'localrouter SSH inbound' allowing TCP $SSH_PORT"
    echo "  - reports whether ollama is on the SSH user's PATH"
    echo "  - reports whether sshd is listening on $SSH_PORT"
    echo
    echo "It will NOT install OpenSSH Server (do that once manually on Windows:"
    echo "  Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0)"
    echo
    echo "Retries: $RETRY_COUNT (backoff ${RETRY_BACKOFF}s linear)."
    echo
    if [[ "$ASSUME_YES" != true ]]; then
        local answer
        read -r -p "Continue? [y/N] " answer
        [[ "$answer" =~ ^[Yy]$ ]] || die "aborted by user"
    fi

    with_retries "setup-windows" _run_setup_windows
    info "Done."
}

open_tunnel() {
    if is_tunnel_active; then
        info "Connection already active. Ready to use."
        state_set LAST_TUNNEL_AT "$(date +%s)"
        return
    fi

    stop_local_ollama_if_needed
    info "Opening SSH tunnel. Press Ctrl+C to close it."

    (
        for _ in {1..60}; do
            if is_port_listening; then
                printf '\nConnection successful. Ready to use.\n'
                state_set LAST_TUNNEL_AT "$(date +%s)" 2>/dev/null || true
                break
            fi
            sleep 0.5
        done
    ) &

    local watcher_pid=$!
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd=(-N -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" "${cmd[@]:1}")
    ssh "${cmd[@]}"
    wait "$watcher_pid" 2>/dev/null || true
}

# ---- new verb commands --------------------------------------------------

format_relative_time() {
    local epoch="$1"
    if [[ -z "$epoch" || "$epoch" == "0" ]]; then
        printf 'never'
        return
    fi
    local now diff
    now="$(date +%s)"
    diff=$((now - epoch))
    local rel
    if   (( diff < 60 ));    then rel="${diff}s ago"
    elif (( diff < 3600 ));  then rel="$((diff / 60))m ago"
    elif (( diff < 86400 )); then rel="$((diff / 3600))h ago"
    elif (( diff < 604800 ));then rel="$((diff / 86400))d ago"
    else                          rel="$((diff / 604800))w ago"
    fi
    local abs
    abs="$(date -d "@$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -r "$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || printf '%s' "$epoch")"
    printf '%s (%s)' "$rel" "$abs"
}

cmd_status() {
    load_config
    read_state
    local cache_status
    if [[ -f "$CACHE_FILE" ]]; then
        cache_status="$(cache_age)s old ($(wc -l <"$CACHE_FILE") models)"
    else
        cache_status="empty"
    fi
    printf 'Config:        %s\n' "$CONFIG_FILE"
    printf 'Models:        %s\n' "$MODELS_FILE"
    printf 'State:         %s\n' "$STATE_FILE"
    printf 'Remote:        %s@%s:%s\n' "${WINDOWS_USER:-<unset>}" "${WINDOWS_HOST:-<unset>}" "$SSH_PORT"
    printf 'Tunnel:        localhost:%s -> %s:%s\n' "$LOCAL_PORT" "$REMOTE_HOST" "$REMOTE_PORT"
    printf 'Target tag:    %s\n' "$TARGET_TAG"
    printf 'Tracked model: %s\n' "${TRACKED_MODEL:-Unknown}"
    if is_tunnel_active; then
        printf 'Tunnel status: %bactive%b\n' "$COLOR_GREEN" "$COLOR_RESET"
    else
        printf 'Tunnel status: inactive\n'
    fi
    printf 'Last tunnel:   %s\n' "$(format_relative_time "$LAST_TUNNEL_AT")"
    printf 'Last pull:     %s\n' "$(format_relative_time "$LAST_PULL_AT")"
    printf 'Last use:      %s\n' "$(format_relative_time "$LAST_USE_AT")"
    printf 'Cache:         %s\n' "$cache_status"
    printf 'Retries:       %d (backoff %ds, pull timeout %ds)\n' "$RETRY_COUNT" "$RETRY_BACKOFF" "$PULL_TIMEOUT"
}

cmd_list() {
    load_config
    validate_config
    require_command ssh
    ( ensure_installed_cache ) 2>/dev/null || info "(warning: could not query remote; showing configured models only)"
    read_models
    read_state

    local tag installed_text size_text mark color status_padded
    printf '\n%bConfigured models%b (%d):\n' "$COLOR_BOLD" "$COLOR_RESET" "${#MODELS[@]}"
    printf '  %-46s  %-12s  %-10s  %s\n' "TAG" "STATUS" "SIZE" "TRACKED"
    for tag in "${MODELS[@]}"; do
        if is_installed "$tag"; then
            color="$COLOR_GREEN"; installed_text="installed"
            size_text="$(installed_size "$tag")"
        else
            color="$COLOR_YELLOW"; installed_text="not pulled"
            size_text="-"
        fi
        mark=""
        [[ -n "$TRACKED_MODEL" && "$tag" == "$TRACKED_MODEL" ]] && mark="*"
        status_padded="$(printf '%-12s' "$installed_text")"
        printf '  %-46s  %b%s%b  %-10s  %s\n' \
            "$tag" "$color" "$status_padded" "$COLOR_RESET" "$size_text" "$mark"
    done

    if [[ -f "$CACHE_FILE" ]]; then
        declare -A known_set=()
        for tag in "${MODELS[@]}"; do known_set["$tag"]=1; done
        local orphans=() orphan_sizes=() raw_tag raw_id raw_size raw_mod
        while IFS=$'\t' read -r raw_tag raw_id raw_size raw_mod; do
            [[ -z "$raw_tag" ]] && continue
            if [[ -z "${known_set[$raw_tag]:-}" ]]; then
                orphans+=("$raw_tag")
                orphan_sizes+=("$raw_size")
            fi
        done <"$CACHE_FILE"
        if (( ${#orphans[@]} > 0 )); then
            printf '\n%bInstalled on %s but not in your list%b (%d):\n' \
                "$COLOR_DIM" "$WINDOWS_HOST" "$COLOR_RESET" "${#orphans[@]}"
            local i
            for i in "${!orphans[@]}"; do
                printf '  %-46s  %s\n' "${orphans[$i]}" "${orphan_sizes[$i]}"
            done
        fi
    fi
    echo
}

tunnel_pids() {
    pgrep -f "ssh .* -L ${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" 2>/dev/null || true
}

cmd_kill() {
    load_config
    require_command pgrep
    local pids
    pids="$(tunnel_pids)"
    if [[ -z "$pids" ]]; then
        info "No localrouter tunnel running for localhost:$LOCAL_PORT -> $REMOTE_HOST:$REMOTE_PORT"
        return 0
    fi
    info "Sending SIGTERM to: $pids"
    # shellcheck disable=SC2086
    kill -TERM $pids 2>/dev/null || true
    local i
    for i in {1..10}; do
        sleep 0.5
        pids="$(tunnel_pids)"
        [[ -z "$pids" ]] && { info "Tunnel closed."; return 0; }
    done
    info "Tunnel did not exit after 5s; escalating to SIGKILL: $pids"
    # shellcheck disable=SC2086
    kill -KILL $pids 2>/dev/null || true
    sleep 0.5
    pids="$(tunnel_pids)"
    if [[ -z "$pids" ]]; then
        info "Tunnel killed."
    else
        die "could not kill tunnel pid(s): $pids"
    fi
}

cmd_restart() {
    load_config
    validate_config
    read_state
    cmd_kill
    if [[ -n "$TRACKED_MODEL" ]]; then
        info "Reopening tunnel with tracked model: $TRACKED_MODEL"
        KEEP_SESSION=true
        SELECTED_MODEL="$TRACKED_MODEL"
        cmd_use_run
    else
        info "No tracked model; opening tunnel without model swap"
        KEEP_SESSION=true
        cmd_use_run
    fi
}

_run_remote_show() {
    local quoted_model="$1"
    local -a cmd
    readarray -d '' -t cmd < <(ssh_base)
    cmd+=("ollama show $quoted_model")
    "${cmd[@]}"
}

cmd_info() {
    [[ -n "${1:-}" ]] || die "usage: localrouter info MODEL"
    local model="$1"
    validate_model_tag "$model" "MODEL"
    load_config
    validate_config
    require_command ssh
    local quoted_model
    quoted_model="$(shell_quote "$model")"
    if is_installed "$model"; then
        printf '%b%s%b — %s\n\n' "$COLOR_BOLD" "$model" "$COLOR_RESET" "installed, $(installed_size "$model" 2>/dev/null || echo unknown)"
    else
        printf '%b%s%b — %bnot installed on %s%b\n\n' "$COLOR_BOLD" "$model" "$COLOR_RESET" "$COLOR_YELLOW" "$WINDOWS_HOST" "$COLOR_RESET"
    fi
    with_retries "ollama show" _run_remote_show "$quoted_model"
}

cmd_watch() {
    load_config
    validate_config
    require_command ssh
    require_command ss
    require_command pgrep

    local backoff=1 rc last_up now uptime
    trap 'info ""; info "Watch mode exiting."; exit 0' INT TERM

    info "${COLOR_BOLD}watch${COLOR_RESET}: $WINDOWS_USER@$WINDOWS_HOST:$SSH_PORT (Ctrl+C to exit)"
    while true; do
        if is_tunnel_active; then
            info "[watch] tunnel already running; sleeping until it drops"
            while is_tunnel_active; do sleep 5; done
            info "[watch] tunnel dropped"
            backoff=1
            continue
        fi
        last_up="$(date +%s)"
        info "[watch] $(date '+%H:%M:%S') opening tunnel"
        local -a cmd
        readarray -d '' -t cmd < <(ssh_base)
        cmd=(-N -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" "${cmd[@]:1}")
        rc=0
        ssh "${cmd[@]}" || rc=$?
        now="$(date +%s)"
        uptime=$((now - last_up))
        state_set LAST_TUNNEL_AT "$last_up" 2>/dev/null || true
        info "[watch] tunnel exited rc=$rc after ${uptime}s"
        if (( uptime > 120 )); then
            backoff=1
        else
            backoff=$(( backoff * 2 ))
            (( backoff > WATCH_BACKOFF_MAX )) && backoff="$WATCH_BACKOFF_MAX"
        fi
        info "[watch] reconnecting in ${backoff}s"
        sleep "$backoff"
    done
}

cmd_use_run() {
    validate_config
    require_command ssh
    require_command ss
    require_command pgrep

    if [[ -n "$SELECTED_MODEL" ]]; then
        validate_model_tag "$SELECTED_MODEL" "MODEL"
    elif [[ "$KEEP_SESSION" != true ]]; then
        choose_model
    fi

    state_set LAST_USE_AT "$(date +%s)"

    if [[ "$KEEP_SESSION" != true && -n "$SELECTED_MODEL" ]]; then
        if [[ "$SELECTED_MODEL" != "${TRACKED_MODEL:-}" || "$FORCE_PULL" == true ]]; then
            info "Connecting to remote host to prepare model: $SELECTED_MODEL"
            remote_ollama_swap "$SELECTED_MODEL"
            state_set TRACKED_MODEL "$SELECTED_MODEL"
        else
            info "$SELECTED_MODEL is already the tracked model."
        fi
    else
        info "Keeping current remote model configuration."
    fi

    open_tunnel
}

cmd_use() {
    if [[ $# -gt 0 ]]; then
        SELECTED_MODEL="$1"
        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --keep) KEEP_SESSION=true; shift ;;
                --force) FORCE_PULL=true; shift ;;
                *) die "unknown option to 'use': $1" ;;
            esac
        done
    fi
    load_config
    read_state
    cmd_use_run
}

cmd_setup() {
    local sub="${1:-}"
    case "$sub" in
        "")              run_setup ;;
        windows)         shift || true; run_setup_windows ;;
        ssh-key|sshkey)  shift || true; run_setup_ssh_key ;;
        *) die "unknown 'setup' subcommand: $sub (use: setup | setup windows | setup ssh-key)" ;;
    esac
}

apply_global_flag() {
    case "$1" in
        --retries)              [[ -n "${2:-}" ]] || die "--retries requires a value"; RETRY_COUNT="$2"; return 2 ;;
        --pull-timeout)         [[ -n "${2:-}" ]] || die "--pull-timeout requires a value"; PULL_TIMEOUT="$2"; return 2 ;;
        --yes)                  ASSUME_YES=true; return 1 ;;
        --no-stop-local-ollama) STOP_LOCAL_OLLAMA_OVERRIDE="no"; return 1 ;;
        --force)                FORCE_PULL=true; return 1 ;;
        --refresh)              FORCE_REFRESH=true; return 1 ;;
        --no-preflight)         PREFLIGHT_OLLAMA=0; return 1 ;;
        --keep)                 KEEP_SESSION=true; return 1 ;;
        --host)                 [[ -n "${2:-}" ]] || die "--host requires a value"
                                info "warning: --host is reserved for future multi-host support and is currently a no-op"
                                return 2 ;;
        --help|-h)              usage; exit 0 ;;
        --version)              printf '%s\n' "$VERSION"; exit 0 ;;
        *)                      return 0 ;;
    esac
}

main() {
    setup_colors

    local verb=""
    local -a verb_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            # legacy flag aliases for one-shot verbs
            --model)
                [[ $# -ge 2 ]] || die "--model requires a value"
                verb="use"; verb_args=("$2"); shift 2 ;;
            --status)            verb="status"; shift ;;
            --setup)             verb="setup"; shift ;;
            --setup-windows)     verb="setup"; verb_args=("windows"); shift ;;
            --setup-ssh-key)     verb="setup"; verb_args=("ssh-key"); shift ;;
            --edit-models)       verb="edit-models"; shift ;;
            --init-config)       verb="init-config"; shift ;;
            # positional verb: rest of argv belongs to it
            use|list|status|kill|restart|info|watch|setup|edit-models|init-config|help|version)
                verb="$1"; shift
                while [[ $# -gt 0 ]]; do
                    apply_global_flag "$1" "${2:-}"; local consumed=$?
                    if   (( consumed == 1 )); then shift
                    elif (( consumed == 2 )); then shift 2
                    else verb_args+=("$1"); shift
                    fi
                done
                break ;;
            *)
                apply_global_flag "$1" "${2:-}"; local consumed=$?
                if   (( consumed == 1 )); then shift
                elif (( consumed == 2 )); then shift 2
                else die "unknown option or verb: $1"
                fi ;;
        esac
    done

    [[ "$verb" == "help" ]] && { usage; exit 0; }
    [[ "$verb" == "version" ]] && { printf '%s\n' "$VERSION"; exit 0; }

    load_config
    if [[ -n "$STOP_LOCAL_OLLAMA_OVERRIDE" ]]; then
        STOP_LOCAL_OLLAMA="$STOP_LOCAL_OLLAMA_OVERRIDE"
    fi

    case "$verb" in
        ""|use)        cmd_use "${verb_args[@]}" ;;
        list)          cmd_list ;;
        status)        cmd_status ;;
        kill)          cmd_kill ;;
        restart)       cmd_restart ;;
        info)          cmd_info "${verb_args[@]}" ;;
        watch)         cmd_watch ;;
        setup)         cmd_setup "${verb_args[@]}" ;;
        edit-models)   edit_models ;;
        init-config)   write_default_config ;;
        *)             die "unknown verb: $verb" ;;
    esac
}

main "$@"
